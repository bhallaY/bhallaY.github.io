<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <meta name="generator" content="{{ eleventy.generator }}"/>
        <title>{{ title or metadata.title }}</title>
        <style>
.article h1, .article h2, .article h3 {
  margin-bottom: 0.5rem;
}
</style>
        <link rel="stylesheet" href="/node_modules/papercss/dist/paper.min.css">
    </head>
    <body class="paper">
        <header>
            {#- Read more about `eleventy-navigation` at https://www.11ty.dev/docs/plugins/navigation/#bring-your-own-html-render-the-menu-items-manually #}
                <nav class="border sticky split-nav">
                    <div class="nav-brand">
                        <h4>
                            <a href="/" class="home-link">{{ metadata.title }}</a>
                        <h4>
                    </div>
                    <div class="collapsible">{% set navPages = collections.all | eleventyNavigation %} 
                        <input id="collapsible1" type="checkbox" name="collapsible1">
                        <label for="collapsible1">
                            <div class="bar1"></div>
                            <div class="bar2"></div>
                            <div class="bar3"></div>
                        </label>
                        <div class="collapsible-body">
                            <ul class="inline">
                                {%- for entry in navPages %}
                                    <li {% if entry.url == page.url %} class="my-active-class" {% endif %}>
                                        <a href="{{ entry.url }}">{{ entry.title }}</a>
                                    </li>
                                {%- endfor %}
                            </ul>
                        </div>
                    </div>
                </nav>
            </header>
            <main>
                {{ content | safe }}
            </main>
            <footer>
                {# TODO: Add contact info I guess #}
            </footer>
        </body>
    </body>
</html>